# Discord
DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=your-application-client-id
# Optional: set to a guild ID during development for instant command registration.
# Leave blank to register commands globally (takes up to 1 hour to propagate).
GUILD_ID=

# Spotify (optional but recommended — register a free app at
# https://developer.spotify.com/dashboard for higher rate limits than the
# default unauthenticated bridge)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Database
DATABASE_FILE=./data/nexusbot.sqlite

# Playback defaults
DEFAULT_VOLUME=80
